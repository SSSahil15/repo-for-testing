{
  "id": null,
  "uid": "devpulse-overview",
  "title": "DevPulse — System Overview",
  "tags": ["devpulse"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"devpulse-backend\"}[2m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (5xx %)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"devpulse-backend\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"devpulse-backend\"}[5m]))",
          "legendFormat": "5xx %"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "unit": "percent",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "API p99 Latency (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(http_request_duration_seconds_bucket{job=\"devpulse-backend\"}[5m]))) * 1000",
          "legendFormat": "p99 ms"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 500, "color": "yellow" },
              { "value": 2000, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Scan Queue Depth",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "bullmq_queue_waiting{job=\"devpulse-backend\",queue=\"scanQueue\"}",
          "legendFormat": "waiting"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate by Route",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(route) (rate(http_requests_total{job=\"devpulse-backend\"}[2m]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "API Latency Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(http_request_duration_seconds_bucket{job=\"devpulse-backend\"}[5m]))) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(http_request_duration_seconds_bucket{job=\"devpulse-backend\"}[5m]))) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(http_request_duration_seconds_bucket{job=\"devpulse-backend\"}[5m]))) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "AI Inference Duration (p50/p95/p99)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(ai_analysis_duration_seconds_bucket{job=\"devpulse-ai\"}[5m]))) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(ai_analysis_duration_seconds_bucket{job=\"devpulse-ai\"}[5m]))) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(ai_analysis_duration_seconds_bucket{job=\"devpulse-ai\"}[5m]))) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "AI Analysis — Success vs Error",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(ai_analysis_requests_total{job=\"devpulse-ai\",status=\"success\"}[2m])",
          "legendFormat": "Success"
        },
        {
          "expr": "rate(ai_analysis_requests_total{job=\"devpulse-ai\",status=\"error\"}[2m])",
          "legendFormat": "Error"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Redis — Memory & Hit Rate",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Memory Used"
        },
        {
          "expr": "rate(redis_keyspace_hits_total[2m]) / (rate(redis_keyspace_hits_total[2m]) + rate(redis_keyspace_misses_total[2m]))",
          "legendFormat": "Hit Rate"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Postgres — Active Connections & Query Rate",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\"}",
          "legendFormat": "Active Connections"
        },
        {
          "expr": "rate(pg_stat_database_xact_commit_total{job=\"postgres\"}[2m])",
          "legendFormat": "Commits/s"
        }
      ]
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Live Application Logs",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=~\"devpulse_backend|devpulse_worker|devpulse_ai\"} | json",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      }
    }
  ]
}
