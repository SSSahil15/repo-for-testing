PORT=4000
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8001

# GitHub OAuth App credentials (get from github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Secrets (min 32 characters each)
TOKEN_ENCRYPTION_SECRET=generate-32-char-random-string-here
JWT_SECRET=generate-32-char-random-string-here

# LLM integration (get from console.groq.com)
GROQ_API_KEY=your-groq-api-key

# Database
DATABASE_PATH=./devpulse.db
NODE_ENV=development

# Sentry (get DSN from sentry.io → devpulse-backend project → Settings → Client Keys)
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_RELEASE=devpulse-backend@local

# CORS — extra allowed origins (comma-separated, no spaces)
# Example: https://devpulse.com,https://staging.devpulse.com
ALLOWED_ORIGINS=
